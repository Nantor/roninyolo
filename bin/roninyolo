#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="${0##*/}"
RY_VERSION="0.1.0"

#######################################
# Default configuration (can be overridden by config files)
#
# Only runtime-agnostic defaults live here.  Agent-specific
# values (image, config dirs, default command) are set by the
# profile — see profiles/<name>/profile.sh.
#######################################

RY_DOCKER_BIN="docker"                     # or "podman"
RY_WORKDIR="/work"

# Which user to run as inside the container:
# - empty (default): run as current host uid:gid (non-root on typical systems)
# - "root": run as root inside the container
# - "opencode": run as the "opencode" user from the Dockerfile
# - "UID:GID": explicit numeric mapping
RY_DOCKER_USER=""

# Env vars passed into the container as KEY=VALUE
RY_ENV_VARS=()

# Additional volumes, e.g. "/data/shared:/data:ro"
RY_ADDITIONAL_VOLUMES=()

# Extra args for "docker run", e.g. "--network=host"
RY_DOCKER_RUN_EXTRA_ARGS=()

# Dockerfile and build context for `roninyolo build`.
# Leave empty here; profiles that ship a Dockerfile set these via
# conditional assignment.  do_build() falls back to "." for the context.
RY_DOCKERFILE=""
RY_BUILD_CONTEXT=""

# Default command (may be set by profile if not overridden in config)
RY_DEFAULT_CMD=()

# Agent profile to load (set in config files; default: opencode)
RY_AGENT_PROFILE="opencode"

# Directory of the active profile (set by load_profile before sourcing profile.sh)
RY_PROFILE_DIR=""

#######################################
# Config loading
#######################################

# Resolve the directory that contains this script (follows symlinks).
# Used to locate bundled profiles/ next to bin/.
_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    # If readlink returned a relative path, resolve it from dir.
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(_resolve_script_dir)"

load_config_file() {
  local file="$1"
  if [[ -r "$file" ]]; then
    # shellcheck source=/dev/null
    . "$file"
  fi
}

# Load an agent profile by name.
# Each profile lives in its own subdirectory as <name>/profile.sh.
# Search paths (first match wins):
#   1. Bundled — <script_dir>/../profiles/<name>/profile.sh
#   2. System — /etc/roninyolo/profiles/<name>/profile.sh
#   3. User   — $HOME/.config/roninyolo/profiles/<name>/profile.sh
#
# RY_PROFILE_DIR is set to the profile's directory before sourcing so that
# profile scripts can reference sibling files (e.g. a co-located Dockerfile).
load_profile() {
  local name="${RY_AGENT_PROFILE:-opencode}"
  local search_paths=(
    "${SCRIPT_DIR}/../profiles/${name}/profile.sh"
    "/etc/roninyolo/profiles/${name}/profile.sh"
    "$HOME/.config/roninyolo/profiles/${name}/profile.sh"
  )

  local p
  for p in "${search_paths[@]}"; do
    if [[ -r "$p" ]]; then
      RY_PROFILE_DIR="$(cd "$(dirname "$p")" && pwd)"
      # shellcheck source=/dev/null
      . "$p"
      return 0
    fi
  done

  echo "ERROR: profile '${name}' not found. Searched:" >&2
  for p in "${search_paths[@]}"; do
    echo "  $p" >&2
  done
  exit 1
}

load_config() {
  # 1. Source config files (may set RY_AGENT_PROFILE and override defaults)
  load_config_file "/etc/roninyolo.conf"
  load_config_file "$HOME/.config/roninyolo.conf"
  load_config_file "$PWD/.roninyolo.conf"

  # 2. Load the selected profile; profile uses conditional assignment
  #    so any value already set by the user's config wins.
  load_profile
}

#######################################
# Usage
#######################################

usage() {
  cat <<EOF
${SCRIPT_NAME} - run CLI agents inside a container with mounted config & working directory

Usage:
  ${SCRIPT_NAME} [run] [CMD ...]   Run container; default CMD comes from the active profile
  ${SCRIPT_NAME} build             Build the configured image from RY_DOCKERFILE
  ${SCRIPT_NAME} init [DIR]        Scaffold a .roninyolo.conf in DIR (default: current directory)
  ${SCRIPT_NAME} profiles          List available agent profiles
  ${SCRIPT_NAME} version           Print version and exit
  ${SCRIPT_NAME} help              Show this help

Agent profiles:
  Set RY_AGENT_PROFILE in a config file to select which agent to run.
  Built-in profiles: opencode (default), aider, claude.

Configuration files (optional, loaded in this order):
  /etc/roninyolo.conf
  \$HOME/.config/roninyolo.conf
  \$PWD/.roninyolo.conf

All configuration is done via these files (no environment-variable based config).
EOF
}

#######################################
# Version
#######################################

do_version() {
  echo "${SCRIPT_NAME} ${RY_VERSION}"
}

#######################################
# Profiles — list available profiles
#######################################

do_profiles() {
  local search_dirs=(
    "${SCRIPT_DIR}/../profiles"
    "/etc/roninyolo/profiles"
    "$HOME/.config/roninyolo/profiles"
  )

  # Collect unique profile names (subdirectory name containing profile.sh)
  local seen=" "
  local name
  local dir
  local f

  for dir in "${search_dirs[@]}"; do
    if [[ -d "$dir" ]]; then
      for f in "$dir"/*/profile.sh; do
        [[ -f "$f" ]] || continue
        # Extract the subdirectory name (the profile name)
        name="${f%/profile.sh}"
        name="${name##*/}"
        # Skip if already seen (dedup across search paths)
        case "$seen" in
          *" ${name} "*) continue ;;
        esac
        seen="${seen}${name} "
        if [[ "$name" = "${RY_AGENT_PROFILE:-opencode}" ]]; then
          echo "${name} (active)"
        else
          echo "$name"
        fi
      done
    fi
  done
}

#######################################
# Init — scaffold a .roninyolo.conf
#######################################

do_init() {
  local target_dir="${1:-.}"
  local conf_file="${target_dir}/.roninyolo.conf"

  if [[ -f "$conf_file" ]]; then
    echo "ERROR: ${conf_file} already exists; refusing to overwrite." >&2
    exit 1
  fi

  mkdir -p "$target_dir"

  cat > "$conf_file" <<'TMPL'
# roninyolo project configuration
# See docs/configuration.md for the full reference.
#
# Variables defined here override per-user and system-wide configs.
# Uncomment and edit the lines you need.

# Agent profile (built-in: opencode, aider, claude)
# RY_AGENT_PROFILE="opencode"

# Container runtime: "docker" or "podman"
# RY_DOCKER_BIN="docker"

# Image to run (tag applied to `docker run` and `docker build -t`; default set by profile)
# RY_IMAGE="roninyolo/opencode:local"

# Host path to config directory (mounted read-only into the container)
# RY_HOST_CONFIG_DIR="$HOME/.config/opencode"

# Where the host config appears inside the container
# RY_CONTAINER_CONFIG_DIR="/root/.config/opencode"

# Working directory inside the container
# RY_WORKDIR="/work"

# User inside the container (empty = current UID:GID)
#   "root"       — run as root
#   "opencode"   — run as the opencode user from the Dockerfile
#   "UID:GID"    — explicit numeric mapping
# RY_DOCKER_USER=""

# Environment variables passed into the container (KEY=VALUE)
# RY_ENV_VARS=(
#   "EDITOR=vim"
# )

# Additional volume mounts
# RY_ADDITIONAL_VOLUMES=(
#   "$PWD/.cache:/work/.cache"
# )

# Extra arguments for "docker run"
# RY_DOCKER_RUN_EXTRA_ARGS=(
#   "--network=host"
# )

# Dockerfile path for `roninyolo build`
# RY_DOCKERFILE=""

# Build context directory
# RY_BUILD_CONTEXT="."

# Default command when no arguments are given
# RY_DEFAULT_CMD=(opencode)
TMPL

  echo "Created ${conf_file}"
}

#######################################
# Build image
#######################################

do_build() {
  if [[ -z "${RY_DOCKERFILE:-}" ]]; then
    # Check if RY_IMAGE is also unset
    if [[ -z "${RY_IMAGE:-}" ]]; then
      echo "INFO: Profile '${RY_AGENT_PROFILE}' is not configured with either:" >&2
      echo "      - a Dockerfile (RY_DOCKERFILE)" >&2
      echo "      - a registry image (RY_IMAGE)" >&2
      echo "      Configure one of these in your profile to enable building." >&2
      exit 1
    else
      echo "INFO: Profile '${RY_AGENT_PROFILE}' uses a registry image ('${RY_IMAGE}'); no local build is needed." >&2
      echo "      Pull it with: ${RY_DOCKER_BIN} pull ${RY_IMAGE}" >&2
      exit 0
    fi
  fi

  local build_context
  if [[ -n "${RY_BUILD_CONTEXT:-}" ]]; then
    build_context="$RY_BUILD_CONTEXT"
  else
    build_context="."
  fi

  echo "Building image '${RY_IMAGE}' from Dockerfile '${RY_DOCKERFILE}' (context: '${build_context}')..."
  exec "${RY_DOCKER_BIN}" build \
    -f "${RY_DOCKERFILE}" \
    -t "${RY_IMAGE}" \
    "${build_context}"
}

#######################################
# Run container
#######################################

do_run() {
  local cmd=()
  if (( $# > 0 )); then
    # If user provides a command, use that
    cmd=("$@")
  else
    # Otherwise use default command
    cmd=("${RY_DEFAULT_CMD[@]}")
  fi

  local args=()
  args+=(--rm -it)

  # Run as configured user; default is current host uid:gid (non-root on typical systems)
  if [[ -n "${RY_DOCKER_USER:-}" ]]; then
    # Use the explicit user from config: can be "root", "opencode" or "UID:GID"
    args+=(-u "${RY_DOCKER_USER}")
  else
    # Default: run as current host user so files in $PWD are owned by you
    args+=(-u "$(id -u):$(id -g)")
  fi

  # Mount opencode config read-only
  args+=(-v "${RY_HOST_CONFIG_DIR}:${RY_CONTAINER_CONFIG_DIR}:ro")

  # Mount current directory as workdir (read-write)
  args+=(-v "$PWD:${RY_WORKDIR}")
  args+=(-w "${RY_WORKDIR}")

  # Env vars into container
  local envvar
  for envvar in "${RY_ENV_VARS[@]}"; do
    args+=(-e "$envvar")
  done

  # Additional volumes
  local vol
  for vol in "${RY_ADDITIONAL_VOLUMES[@]}"; do
    args+=(-v "$vol")
  done

  # Extra docker run args
  args+=("${RY_DOCKER_RUN_EXTRA_ARGS[@]}")

  # Run container; when CMD exits (e.g. opencode), container exits
  exec "${RY_DOCKER_BIN}" run "${args[@]}" "${RY_IMAGE}" "${cmd[@]}"
}

#######################################
# Main
#######################################

main() {
  load_config

  local subcmd="run"

  if (( $# > 0 )); then
    case "$1" in
      run)
        subcmd="run"
        shift
        ;;
      build)
        subcmd="build"
        shift
        ;;
      init)
        subcmd="init"
        shift
        ;;
      profiles)
        subcmd="profiles"
        shift
        ;;
      version|--version|-V)
        do_version
        exit 0
        ;;
      help|-h|--help)
        usage
        exit 0
        ;;
      *)
        subcmd="run"
        ;;
    esac
  fi

  case "$subcmd" in
    build)    do_build "$@"    ;;
    init)     do_init "$@"     ;;
    profiles) do_profiles "$@" ;;
    run)      do_run "$@"      ;;
  esac
}

main "$@"
